# ========== Docker Compose（根目录）==========
COMPOSE_PROJECT_NAME=aihr-app
POSTGRES_USER=aihr_app
POSTGRES_PASSWORD=aihr_local_change_me
POSTGRES_DB=aihr_app
POSTGRES_PORT=25432
# 默认 26379，避免与本机/其他项目 Redis 冲突
REDIS_PORT=26379
API_PORT=3300

# 请求体上限：如 2mb、500kb；或整数字节 BODY_SIZE_LIMIT_BYTES=2097152
# BODY_SIZE_LIMIT=2mb
# 套接字读超时（毫秒，仅显式设置时生效，适合大文件/慢反代）
# HTTP_SERVER_TIMEOUT_MS=

# API 容器 / 本地 apps/api 共用
# 本机连 Docker 中的 AIHR 专用 Postgres（见 docker-compose 默认端口 25432）
# 可选在 URL 查询串追加：&connection_limit=10&connect_timeout=5&pool_timeout=10（高并发/云 DB 时按实例规格调整）
DATABASE_URL=postgresql://aihr_app:aihr_local_change_me@127.0.0.1:25432/aihr_app?schema=public
# 为 true 时 Prisma 打印 SQL（仅排障，生产勿开）
PRISMA_LOG_QUERIES=false
JWT_SECRET=dev-change-me-use-long-random-string
JWT_EXPIRES_IN=7d
DEFAULT_TENANT_SLUG=default
LOCAL_SIMULATOR_ENABLED=true

# 微信小程序（腾讯 jscode2session）
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=

# 种子管理员（npm run prisma:seed --prefix apps/api）
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# 置于反代/网关之后时设为 1 或 2（代理层数），使限流等按真实客户端 IP 计算；直连调试勿开
# TRUST_PROXY=1

# 多 Pod/多进程限流共享；留空则仅进程内计数。本机连 Docker Redis：redis://127.0.0.1:26379
# docker-compose 中 API 默认已指向 compose 内 Redis；本地直连 API 不经过 compose 时可按需填写
# THROTTLER_REDIS_URL=

# 管理端 / 小程序模拟器 CORS，逗号分隔；留空则开发期允许任意来源（见 main.ts）
CORS_ORIGINS=http://localhost:15174,http://localhost:15175
# 管理端 Vite 开发代理；默认指向 Docker 新 API 端口
VITE_API_PROXY_TARGET=http://localhost:3300
VITE_ADMIN_WEB_PORT=15174
VITE_MINIPROGRAM_SIM_PORT=15175

# ========== 微信支付 v3（平台单一商户，可选）==========
# 全部配置且 WECHAT_PAY_NOTIFY_URL 为公网 HTTPS 时，POST /v1/payments/wechat/jsapi 将走真实统一下单
WECHAT_PAY_MCH_ID=
WECHAT_PAY_CERT_SERIAL=
WECHAT_PAY_API_V3_KEY=
# 公网可访问的回调 URL，须与商户平台配置一致，例如 https://api.example.com/v1/payments/wechat/notify
WECHAT_PAY_NOTIFY_URL=
# 若与小程序不同 AppID 可单独配置；默认同 WECHAT_MINI_APP_ID
WECHAT_PAY_APP_ID=
# 商户 API 私钥 PEM：二选一
WECHAT_PAY_PRIVATE_KEY_PATH=
# WECHAT_PAY_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
WECHAT_PAY_PRIVATE_KEY_PEM=

# ========== 腾讯云短信（可选）==========
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
SMS_SDK_APP_ID=
SMS_SIGN_NAME=
# 模板正文建议仅 1 个参数：验证码，对应 TemplateParamSet[0]
SMS_TEMPLATE_ID_OTP=
SMS_REGION=ap-guangzhou
# 验证码 HMAC 盐，生产务必使用长随机串
SMS_CODE_PEPPER=

# ========== 腾讯会议（模拟面试，可选）==========
# 为 true 时请在 TencentMeetingService 中实现创建会议/入会链接 HTTP 调用；否则返回占位供联调
TENCENT_MEETING_API_ENABLED=false

# ========== 腾讯 TRTC / VR 场景（模拟面试，可选）==========
# 为 true 时请接入 UserSig 签发与房间生命周期；否则返回可联调占位房间
TRTC_API_ENABLED=false
TRTC_SDK_APP_ID=
# VR 场景资源由业务侧/前端场景引擎定义；管理端可逐场会话设置 vrSceneKey / vrSceneName
