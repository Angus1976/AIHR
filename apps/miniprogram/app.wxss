/**
 * 屏幕适配说明（微信官方 750 设计宽度 + rpx）：
 * - 布局、字号、圆角等尽量使用 rpx，随屏幕宽度等比缩放。
 * - 安全区用 env()/constant()，适配刘海、圆角屏与底部横条。
 * - 避免 100vw：部分机型 vw 与滚动条组合会产生横向溢出，用 100%。
 * - 窄屏/大屏用 @media 微调边距与侧栏，避免极端尺寸下过于拥挤或过疏。
 */
page {
  /* Jobde 品牌色：深藏青 + 青绿点缀 */
  --primary: #1e3a5f;
  --primary-strong: #152a45;
  --accent: #00a89a;
  --accent-soft: rgba(0, 168, 154, 0.18);
  --sage: #5a9e96;
  --bg: #f0f4f8;
  --paper: #fffdf8;
  --text: #1a2433;
  --muted: #5c6678;
  --line: #d5dde8;
  --success: #009688;
  --success-bg: #e0f5f3;
  --warning: #9a5b25;
  --warning-bg: #f4dfbf;
  --button-text: #fffaf1;
  --card-margin: 24rpx;
  --card-padding: 32rpx;
  background:
    linear-gradient(180deg, #f8fafc 0%, var(--bg) 52%, #e8eef5 100%);
  color: var(--text);
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Noto Sans SC', sans-serif;
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
  overflow-x: hidden;
}

view,
text,
button,
input,
textarea,
navigator,
label {
  box-sizing: border-box;
  max-width: 100%;
  min-width: 0;
}

/* 根容器：全机型避免横向撑破 + 底部 Home Indicator 安全区 */
.page {
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
  min-height: 0;
  min-width: 0;
  overflow-x: hidden;
  padding-left: max(0rpx, constant(safe-area-inset-left));
  padding-left: max(0rpx, env(safe-area-inset-left));
  padding-right: max(0rpx, constant(safe-area-inset-right));
  padding-right: max(0rpx, env(safe-area-inset-right));
  padding-bottom: calc(40rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.card {
  margin: var(--card-margin);
  padding: var(--card-padding);
  background: rgba(255, 253, 248, 0.92);
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 44rpx rgba(49, 57, 42, 0.08);
  box-sizing: border-box;
  max-width: 100%;
  overflow: hidden;
  word-wrap: break-word;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.topline,
.title-row,
.row,
.meta {
  max-width: 100%;
  min-width: 0;
}

.topline > view,
.title-row > view,
.row > view,
.meta > view,
.meta > text {
  min-width: 0;
}

.btn-primary {
  margin-top: 24rpx;
  background: linear-gradient(180deg, #2a5080, var(--primary-strong));
  color: var(--button-text);
  border-radius: 22rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(36, 63, 52, 0.18);
  box-sizing: border-box;
  max-width: 100%;
  width: 100%;
}

.muted {
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.6;
}

.warn {
  color: var(--warning) !important;
}

.ok {
  color: var(--success) !important;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: var(--success-bg);
  color: var(--success);
  font-size: 22rpx;
  font-weight: 700;
}

.input,
.area,
.pitch,
textarea {
  background: rgba(255, 253, 248, 0.86);
  border-color: var(--line) !important;
  box-sizing: border-box;
  max-width: 100%;
}

/* 全局长文与代码串不换行时仍可收缩 */
text,
.muted,
.desc,
.deliverable,
.title,
.section-title,
.name,
.code,
.status,
.price,
.note {
  word-break: break-word;
  overflow-wrap: anywhere;
}

.code,
.mono {
  word-break: break-all;
}

image {
  max-width: 100%;
  height: auto;
  vertical-align: top;
}

/* 首页 / 服务等页纵向步骤条（与侧栏圆点联动） */
.page-with-flow {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding-left: 4rpx;
  gap: 0;
}

.flow-rail {
  position: sticky;
  top: 12rpx;
  flex: 0 0 72rpx;
  max-width: 72rpx;
  min-width: 0;
  padding: 10rpx 4rpx 18rpx 6rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  border-right: 1rpx solid var(--line);
  background: rgba(255, 253, 248, 0.78);
  border-radius: 0 16rpx 16rpx 0;
  box-sizing: border-box;
}

.flow-track {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 6rpx 0;
}

.flow-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: var(--line);
  transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
}

.flow-dot.done {
  background: var(--accent);
}

.flow-dot.done-lock {
  background: var(--sage);
  opacity: 0.92;
}

.flow-dot.todo {
  background: #c9c3b8;
}

.flow-dot.active {
  box-shadow: 0 0 0 4rpx var(--accent-soft);
  transform: scale(1.12);
}

.flow-cap {
  font-size: 20rpx;
  font-weight: 800;
  color: var(--primary-strong);
  text-align: center;
  line-height: 1.3;
  max-width: 64rpx;
}

.flow-next {
  font-size: 18rpx;
  font-weight: 700;
  color: var(--accent);
  text-align: center;
  line-height: 1.35;
  max-width: 66rpx;
}

.flow-hint {
  font-size: 16rpx;
  line-height: 1.4;
  color: var(--muted);
  text-align: center;
  max-width: 66rpx;
}

.flow-main {
  flex: 1;
  min-width: 0;
}

.flow-main--full {
  flex: 1;
  width: 100%;
}

.flow-anchor--stack .card {
  margin-top: 0;
}

.flow-anchor--stack .card + .card {
  margin-top: 24rpx;
}

/* —— 极端窄屏（如部分小屏安卓 / 分屏）：略减卡片边距，保证可点区域 */
@media (max-width: 340px) {
  page {
    --card-margin: 16rpx;
    --card-padding: 26rpx;
  }

  .flow-rail {
    flex: 0 0 64rpx;
    max-width: 64rpx;
    padding: 8rpx 2rpx 14rpx 4rpx;
  }

  .flow-cap {
    font-size: 18rpx;
    max-width: 58rpx;
  }

  .flow-next {
    font-size: 16rpx;
    max-width: 58rpx;
  }

  .flow-hint {
    font-size: 14rpx;
    max-width: 58rpx;
  }

  .btn-primary {
    font-size: 26rpx;
    padding: 18rpx 32rpx;
  }
}

/* —— 较宽屏：在安全区外再留少量 rpx 边距（calc 为基础库 2.10+ 常见写法） */
@media (min-width: 480px) {
  .page {
    padding-left: calc(12rpx + constant(safe-area-inset-left));
    padding-left: calc(12rpx + env(safe-area-inset-left));
    padding-right: calc(12rpx + constant(safe-area-inset-right));
    padding-right: calc(12rpx + env(safe-area-inset-right));
  }
}

@media (min-width: 768px) {
  page {
    --card-margin: 28rpx;
  }

  .page {
    padding-left: calc(20rpx + constant(safe-area-inset-left));
    padding-left: calc(20rpx + env(safe-area-inset-left));
    padding-right: calc(20rpx + constant(safe-area-inset-right));
    padding-right: calc(20rpx + env(safe-area-inset-right));
  }
}
