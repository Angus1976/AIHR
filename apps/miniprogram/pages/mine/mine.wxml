<view class="page">
  <view class="hero card intro">
    <view class="section-title">个人中心</view>
    <view class="muted">档案、投递进度、面试确认、协议与订单等入口统一收纳，首页仅保留浏览与下单主路径。</view>
  </view>

  <navigator class="card link-card" url="/pages/profile/profile" hover-class="none">
    <view class="section-title">我的档案</view>
    <view class="muted">填写技能与经历摘要，岗位详情可显示匹配参考</view>
  </navigator>

  <navigator class="card link-card" url="/pages/applications/applications" hover-class="none">
    <view class="section-title">我的投递</view>
    <view class="muted">查看已投递岗位、状态与留言</view>
  </navigator>

  <navigator class="card link-card" url="/pages/interview-ops/interview-ops" hover-class="none">
    <view class="section-title">面试机会确认</view>
    <view class="muted">平台推送企业面试机会后，在此确认参加或拒绝（6 步服务之「面试确认」）</view>
  </navigator>

  <navigator class="card link-card" url="/pages/notifications/notifications" hover-class="none">
    <view class="title-row">
      <view class="section-title">消息通知</view>
      <text wx:if="{{unreadCount}}" class="badge">{{unreadCount}}</text>
    </view>
    <view class="muted">查看投递状态、伙伴审核等平台通知</view>
  </navigator>

  <navigator class="card link-card" url="/pages/contracts/contracts" hover-class="none">
    <view class="section-title">我的协议</view>
    <view class="muted">查看并签署平台生成的服务协议</view>
  </navigator>

  <navigator class="card link-card" url="/pages/billing/billing" hover-class="none">
    <view class="section-title">订单与退款</view>
    <view class="muted">查看订单并提交退款申请</view>
  </navigator>

  <navigator class="card link-card" url="/pages/partner-apply/partner-apply" hover-class="none">
    <view class="section-title">伙伴入驻</view>
    <view class="muted">培训机构、猎头或服务商提交资质与服务摘要</view>
  </navigator>
</view>
