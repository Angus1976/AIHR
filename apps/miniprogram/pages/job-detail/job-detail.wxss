.title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
  word-break: break-word;
  overflow-wrap: anywhere;
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}
.jd {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text);
  white-space: pre-wrap;
  word-break: break-word;
  overflow-wrap: anywhere;
  display: block;
  max-width: 100%;
}
.pitch {
  width: 100%;
  min-height: 160rpx;
  margin-bottom: 16rpx;
  padding: 16rpx;
  border: 1px solid var(--line);
  border-radius: 12rpx;
  box-sizing: border-box;
}

.match-line {
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.match-num {
  font-weight: 700;
  color: var(--accent);
}

.match-hint {
  font-size: 26rpx;
  line-height: 1.5;
}
