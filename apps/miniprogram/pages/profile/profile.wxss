.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.tip {
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 1px solid var(--line);
  border-radius: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.area {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  border: 1px solid var(--line);
  border-radius: 16rpx;
  box-sizing: border-box;
  font-size: 26rpx;
}

.area.tall {
  min-height: 320rpx;
}

.warn {
  color: var(--warning);
  font-size: 26rpx;
}

.ok {
  color: var(--success);
  font-size: 26rpx;
}
