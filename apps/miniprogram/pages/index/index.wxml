<view class="page page-with-flow">
  <view class="flow-rail">
    <view class="flow-track">
      <view wx:for="{{flowDots}}" wx:key="index" class="flow-dot {{item.tone}}"></view>
    </view>
    <text class="flow-cap">第 {{flowActiveIndex + 1}} / {{flowStepCount}} 步</text>
    <text class="flow-next">{{flowNextLabel}}</text>
    <text class="flow-hint">青绿色圆点：已滑过的区块；灰色：尚未浏览；外圈高亮为当前视区中心附近的区块。请按提示完成「下一步」。</text>
  </view>

  <view class="flow-main">
    <view class="hero card flow-anchor brand-hero">
      <image class="brand-logo-img" src="/images/brand-logo.png" mode="widthFix" />
      <view class="eyebrow">Jobde</view>
      <view class="title">职得</view>
      <view class="subtitle muted">从岗位匹配、协议签署到服务付费，一站式就业服务工作流。</view>
    </view>

    <navigator class="card link-card flow-anchor" url="/pages/jobs/jobs" hover-class="none">
      <view class="section-title">在招岗位</view>
      <view class="muted">浏览已发布岗位并投递</view>
    </navigator>

    <view class="flow-anchor flow-anchor--stack">
      <view class="card">
        <view class="section-title">服务可用性</view>
        <view wx:if="{{error}}" class="muted warn">{{error}}</view>
        <block wx:else>
          <view class="muted">GET /v1/health</view>
          <text class="code">{{health ? JSON.stringify(health) : '加载中…'}}</text>
        </block>
        <button class="btn-primary" bindtap="checkHealth">重新检测</button>
      </view>

      <view class="card">
        <view class="section-title">微信登录</view>
        <view class="muted">调用 wx.login 后向服务端换取 JWT（需配置 AppSecret）。</view>
        <button class="btn-primary" loading="{{logging}}" bindtap="onLogin">一键登录</button>
      </view>

      <view class="card">
        <view class="section-title">支付预下单（联调）</view>
        <view class="muted">先登录；配置商户后走 live 并调起 wx.requestPayment，否则为 stub。</view>
        <button class="btn-primary" loading="{{paying}}" bindtap="onPaySmoke">1 分测试预下单</button>
        <view wx:if="{{payResult}}" class="muted" style="margin-top:16rpx">{{payResult}}</view>
      </view>
    </view>
  </view>
</view>
