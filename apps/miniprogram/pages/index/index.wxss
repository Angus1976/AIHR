.hero {
  position: relative;
  overflow: hidden;
  padding: 48rpx 40rpx;
  background:
    linear-gradient(145deg, rgba(255, 253, 248, 0.96), rgba(242, 223, 189, 0.54));
}

.hero::after {
  content: '';
  position: absolute;
  right: -86rpx;
  top: -86rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 999rpx;
  background: var(--accent-soft);
}

.eyebrow {
  position: relative;
  z-index: 1;
  color: var(--accent);
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  margin-bottom: 14rpx;
}

.hero .title {
  position: relative;
  z-index: 1;
  font-size: 58rpx;
  line-height: 1.05;
  font-weight: 800;
  color: var(--primary-strong);
  max-width: 100%;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.hero .subtitle {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  max-width: 100%;
  font-size: 26rpx;
  word-break: break-word;
}

.section-title {
  font-size: 31rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  color: var(--primary-strong);
}

.code {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--muted);
  word-break: break-all;
}

.link-card {
  text-decoration: none;
  color: inherit;
  display: block;
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.badge {
  min-width: 42rpx;
  height: 42rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: var(--accent);
  color: var(--button-text);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
}
